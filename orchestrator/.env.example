# Supabase — obrigatório
# Obter em: supabase.com → projeto → Settings → API
SUPABASE_URL=https://[projeto-id].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis — obrigatório
# Obter em: console.upstash.com → Redis → seu banco → REST API
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
UPSTASH_REDIS_TOKEN=AX...

# Groq — obrigatório para a IA Flora (SDR)
# Obter em: console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Anthropic — necessário para agentes que usam Claude
# Obter em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Ambiente
NODE_ENV=development

# WhatsApp via Z-API — obrigatório para envio/recebimento WhatsApp
# Painel Z-API: https://app.z-api.io
#   ZAPI_INSTANCE_ID  → Instâncias > sua instância > ID
#   ZAPI_TOKEN        → Instâncias > sua instância > Token
#   ZAPI_CLIENT_TOKEN → Minha Conta > Client-Token (conta, não instância)
WHATSAPP_PROVIDER=zapi
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Webhook URL que deve ser cadastrada na Z-API:
#   https://seu-orquestrador.onrender.com/webhook/whatsapp

# Notificações para Carlos (número do operador, formato: 5511999999999)
CARLOS_WHATSAPP=5511999999999

# Meta / Instagram / Facebook — obrigatório para DMs do Instagram e Messenger
META_VERIFY_TOKEN=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_IG_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_ID=
INSTAGRAM_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=

# Melhor Envio — obrigatório para cotação e geração de etiqueta
# Obter em: melhorenvio.com.br → Painel → Meu Perfil → Tokens de Acesso
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true

# Lalamove — opcional, para entrega urbana same-day
# Obter em: partnerportal.lalamove.com → Developers
LALAMOVE_API_KEY=
LALAMOVE_API_SECRET=
LALAMOVE_ENVIRONMENT=sandbox
LALAMOVE_MARKET=BR

# Cielo — obrigatório para link de pagamento
CIELO_MERCHANT_ID=
CIELO_CLIENT_ID=
CIELO_CLIENT_SECRET=

# Mercado Pago — opcional, só se webhook-mercadopago estiver em uso
# (ver docs/MISSING_SOURCE_FUNCTIONS.md — status nao confirmado)
MERCADOPAGO_ACCESS_TOKEN=

# WordPress / WooCommerce — obrigatório para catálogo ao vivo (scraping)
WORDPRESS_SITE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Identidade e localização da loja — obrigatório
AGENT_NAME=
WORKSPACE_NAME=
BUSINESS_SEGMENT=floricultura
STORE_CITY=
STORE_STATE=
STORE_ADDRESS=
STORE_CEP=
STORE_LATITUDE=
STORE_LONGITUDE=
STORE_WHATSAPP_NUMBER=
STORE_WHATSAPP_LINK=
STORE_PIX_KEY=
STORE_HUMAN_PHONE=

# Thresholds de negócio — opcional, usado em regras de aprovação/escalonamento
HUMAN_APPROVAL_THRESHOLD=500
ESCALATION_THRESHOLD=500
